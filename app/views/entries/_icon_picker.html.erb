<%# Renders an icon picker: emoji grid + image upload %>
<%# locals: form (form builder), entry (Entry record) %>
<div class="icon-picker" data-controller="icon-picker">
  <div class="icon-picker__preview" data-icon-picker-target="preview">
    <% if entry.icon_image.attached? %>
      <%= image_tag entry.icon_image, class: "icon-picker__img" %>
    <% else %>
      <span class="icon-picker__emoji"><%= entry.display_icon %></span>
    <% end %>
  </div>

  <div class="icon-picker__options">
    <div class="icon-picker__grid">
      <% Entry::ICON_EMOJIS.each do |emoji| %>
        <button type="button"
                class="icon-picker__btn <%= 'icon-picker__btn--selected' if entry.display_icon == emoji && !entry.icon_image.attached? %>"
                data-action="click->icon-picker#selectEmoji"
                data-icon-picker-emoji-param="<%= emoji %>">
          <%= emoji %>
        </button>
      <% end %>
    </div>

    <div class="icon-picker__upload">
      <label class="btn btn-outline-secondary btn-sm">
        📷 Upload image
        <%= form.file_field :icon_image,
              accept: "image/*",
              class: "d-none",
              data: { action: "change->icon-picker#uploadImage", icon_picker_target: "fileInput" } %>
      </label>
      <button type="button"
              class="btn btn-outline-danger btn-sm"
              data-action="click->icon-picker#removeImage"
              data-icon-picker-target="removeBtn"
              style="<%= 'display:none' unless entry.icon_image.attached? %>">
        Remove image
      </button>
    </div>
  </div>

  <%= form.hidden_field :icon, value: entry.display_icon, data: { icon_picker_target: "iconField" } %>
  <input type="hidden" name="purge_icon_image" value="0" data-icon-picker-target="purgeField">
</div>
