<div data-controller="map"
     data-map-create-url-value="<%= pins_path %>"
     class="map-layout">

  <%# ── Left column: pan/zoom map viewport ── %>
  <div class="map-layout__map">
    <div id="map-container"
         class="map-viewport"
         data-map-target="viewport">

      <div class="map-canvas" data-map-target="canvas">
        <%= image_tag "example1.png",
              class: "map-canvas__image",
              draggable: false,
              alt: "Floor plan map" %>
      </div>

      <div id="pins-container" data-map-target="pins">
        <%= render @pins %>
      </div>

      <div class="map-controls">
        <button type="button" class="map-controls__btn" data-action="click->map#zoomIn" title="Zoom in">+</button>
        <button type="button" class="map-controls__btn" data-action="click->map#zoomOut" title="Zoom out">-</button>
        <button type="button" class="map-controls__btn" data-action="click->map#resetView" title="Reset view">⟲</button>
      </div>

      <p id="map-hint" class="map-hint" style="display:none;">
        Click to place pin · <kbd>Esc</kbd> cancel
      </p>
    </div>
  </div>

  <%# ── Right column: entry list + expand panel ── %>
  <div class="map-layout__entries">

    <%# ── Entry list (hidden when an entry is expanded) ── %>
    <div id="entry-list" data-map-target="entryList">
      <% @entries.each do |entry| %>
        <div class="entry-row" id="entry-card-<%= entry.id %>"
             data-action="mouseenter->map#highlight mouseleave->map#unhighlight"
             data-map-entry-id-param="<%= entry.id %>">

          <div class="entry-row__thumb">
            <% if entry.icon_image.attached? %>
              <%= image_tag entry.icon_image, class: "entry-row__thumb-img" %>
            <% else %>
              <%= entry.display_icon %>
            <% end %>
          </div>

          <div class="entry-row__info">
            <strong class="entry-row__name"><%= entry.name %></strong>
            <span class="entry-row__meta">Last modified <%= time_ago_in_words(entry.updated_at) %> ago</span>
            <% if entry.watering_frequency.present? %>
              <span class="entry-row__water <%= 'entry-row__water--needs' if entry.needs_watering? %>">
                <%= entry.needs_watering? ? "💧 Needs watering" : "✅ Watered" %>
                <small>· every <%= pluralize(entry.watering_frequency, 'day') %></small>
              </span>
            <% end %>
          </div>

          <div class="entry-row__actions">
            <button class="btn btn-outline-secondary btn-sm"
                    data-action="click->map#startPlacing"
                    data-map-entry-id-param="<%= entry.id %>"
                    id="place-pin-btn-<%= entry.id %>">
              <%= entry.pin.present? ? "📍 Move Pin" : "📍 Pin" %>
            </button>
            <button class="btn btn-outline-secondary btn-sm"
                    data-action="click->map#expandEntry"
                    data-map-entry-id-param="<%= entry.id %>">
              ✏️ Edit
            </button>
            <%= button_to "🗑", entry, method: :delete,
                  class: "btn btn-outline-danger btn-sm",
                  data: { confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Expanded entry panel (hidden by default) ── %>
    <div id="entry-expand" class="entry-expand" style="display:none;" data-map-target="entryExpand">
      <% @entries.each do |entry| %>
        <div class="entry-expand__panel" id="entry-panel-<%= entry.id %>" style="display:none;">
          <%= form_with(model: entry, class: "entry-expand__form", data: { turbo: false }) do |f| %>

            <div class="mb-3">
              <label class="form-label fw-bold">Icon</label>
              <%= render "entries/icon_picker", form: f, entry: entry %>
            </div>

            <div class="entry-expand__fields">
              <label class="form-label fw-bold">Plant Name</label>
              <%= f.text_field :name, class: "form-control mb-3" %>

              <label class="form-label fw-bold">Watering frequency (days)</label>
              <div class="d-flex align-items-center gap-3 mb-3">
                <%= f.range_field :watering_frequency,
                      min: 1, max: 30,
                      value: entry.watering_frequency || 7,
                      class: "form-range flex-grow-1",
                      oninput: "this.nextElementSibling.textContent = this.value + 'd'" %>
                <span class="text-muted"><%= entry.watering_frequency || 7 %>d</span>
              </div>

              <label class="form-label fw-bold">Link</label>
              <%= f.text_field :link, class: "form-control mb-3", placeholder: "https://..." %>
            </div>

            <hr>

            <div class="entry-expand__notes">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-bold">Notes</span>
              </div>
              <%= f.text_area :notes,
                    class: "form-control entry-expand__notes-area",
                    rows: 6,
                    placeholder: "Add notes about this plant..." %>
            </div>

            <div class="entry-expand__footer">
              <%= f.submit "Save", class: "btn btn-primary" %>
              <button type="button" class="btn btn-outline-secondary"
                      data-action="click->map#collapseEntry">
                ← Back
              </button>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>
</div>
