<div data-controller="map"
     data-map-create-url-value="<%= pins_path %>"
     class="map-layout">

  <%# ── Left column: floor plan map ── %>
  <div class="map-layout__map">
    <div id="map-container"
         class="map-container"
         data-map-target="container">

      <p id="map-hint" class="map-hint" style="display:none;">
        Click on the map to place the pin. Press <kbd>Esc</kbd> to cancel.
      </p>

      <%= image_tag "map_background.png",
            class: "map-container__image",
            draggable: false,
            alt: "Floor plan map" %>

      <div id="pins-container">
        <%= render @pins %>
      </div>
    </div>
  </div>

  <%# ── Right column: scrollable entry list ── %>
  <div class="map-layout__entries">
    <% @entries.each do |entry| %>
      <div class="entry-row" id="entry-card-<%= entry.id %>"
           data-action="mouseenter->map#highlightPin mouseleave->map#unhighlightPin"
           data-map-entry-id-param="<%= entry.id %>">

        <div class="entry-row__thumb">
          🌱
        </div>

        <div class="entry-row__details">
          <ul class="entry-row__list">
            <li><strong><%= entry.name %></strong></li>
            <li><%= link_to entry.link, entry.link, target: "_blank" %></li>
            <li class="text-muted"><small>Added <%= time_ago_in_words(entry.created_at) %> ago</small></li>
            <li>
              <button class="btn btn-outline-secondary btn-sm"
                      data-action="click->map#startPlacing"
                      data-map-entry-id-param="<%= entry.id %>"
                      id="place-pin-btn-<%= entry.id %>">
                <%= entry.pin.present? ? "🗺️ Move Pin" : "📍 Place Pin" %>
              </button>
              <%= button_to "Delete", entry, method: :delete,
                    class: "btn btn-outline-danger btn-sm",
                    data: { confirm: "Are you sure?" } %>
            </li>
          </ul>
        </div>
      </div>
    <% end %>
  </div>

</div>
