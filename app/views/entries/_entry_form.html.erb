<%# Shared form body for new + edit entry %>
<%# locals: f (form builder), entry (Entry record) %>

<div class="mb-3">
  <label class="form-label fw-bold">Icon</label>
  <%= render "entries/icon_picker", form: f, entry: entry %>
</div>

<div class="entry-expand__fields">
  <label class="form-label fw-bold">Plant Name</label>
  <%= f.text_field :name, class: "form-control mb-3", required: true %>

  <label class="form-label fw-bold">Watering frequency (days)</label>
  <div class="d-flex align-items-center gap-3 mb-3">
    <%= f.range_field :watering_frequency,
          min: 1, max: 30,
          value: entry.watering_frequency || 7,
          class: "form-range flex-grow-1",
          oninput: "this.nextElementSibling.textContent = this.value + 'd'" %>
    <span class="text-muted"><%= entry.watering_frequency || 7 %>d</span>
  </div>
</div>

<hr>

<div class="entry-expand__notes">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <span class="fw-bold">Notes</span>
  </div>
  <%= f.text_area :notes,
        class: "form-control entry-expand__notes-area",
        rows: 6,
        placeholder: "Add notes about this plant..." %>
</div>

<% if entry.persisted? && entry.last_modified_by %>
  <p class="entry-expand__modified-by">
    ✍️ Last modified by <%= entry.last_modified_by.email %>
  </p>
<% end %>
